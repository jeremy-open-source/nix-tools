#!/usr/bin/env bash

set -eu -o pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $(basename "$0") <target> [args...]" >&2
  exit 1
fi

if ! git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
  echo "Error: Not inside a git repository" >&2
  exit 1
fi

target_name="$1"
shift

git_root="$(cd "$git_root" && pwd -P)"
current_dir="$(pwd -P)"
if [[ "$current_dir" == "$git_root" ]]; then
  rel_dir=""
else
  rel_dir="${current_dir#"$git_root"/}"
  if [[ "$rel_dir" == "$current_dir" ]]; then
    echo "Error: Current directory is outside git root: $git_root" >&2
    exit 1
  fi
fi

bazel_target="//"
if [[ -n "$rel_dir" ]]; then
  bazel_target+="${rel_dir}"
fi
bazel_target+=":${target_name}"

cmd=(bazel run "$bazel_target" -- "$@")
printf 'INFO: Running'
printf ' %q' "${cmd[@]}"
printf '\n'

exec "${cmd[@]}"
