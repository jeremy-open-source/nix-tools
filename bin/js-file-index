#!/usr/bin/env python3

"""
Build YAML file indexes for directories, detect duplicate content, and compare
one index against another.

Common use cases:
- Create an index for an unsorted photo import.
- Create an index for a NAS photo library.
- Compare the two indexes to confirm every imported photo exists in the NAS,
  even if the destination folders are different.

Examples:
    js-file-index --create-index --directory /photos/import --output-file import.yml
    js-file-index --create-index --directory /mnt/nas/photos --output-file nas.yml
    js-file-index --compare-indexes --output-file nas.yml --other-index import.yml
    js-file-index --compare-indexes --output-file nas.yml --other-index import.yml --match-name
"""

import os
import hashlib
import yaml
import argparse
import logging
import mimetypes
import subprocess
import json
import shutil
from datetime import datetime
from typing import Any

logger = logging.getLogger(__name__)

INDEX_VERSION = "2"
DEFAULT_OUTPUT_FILE = "js_file_index.yml"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Manage file indexes with SHA-256 hashes.",
        epilog=(
            "Examples:\n"
            "  js-file-index --create-index --directory /photos/import --output-file import.yml\n"
            "  js-file-index --create-index --directory /mnt/nas/photos --output-file nas.yml\n"
            "  js-file-index --compare-indexes --output-file nas.yml --other-index import.yml\n"
            "  js-file-index --compare-indexes --output-file nas.yml --other-index import.yml --match-name"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    action_group = parser.add_mutually_exclusive_group(required=True)
    action_group.add_argument("--create-index", action="store_true", help="Re-create the file index")
    action_group.add_argument("--add-missing", action="store_true", help="Add missing files to the index")
    action_group.add_argument(
        "--duplicate-hashes",
        action="store_true",
        help="Find duplicate file hashes and print them",
    )
    action_group.add_argument(
        "--duplicate-hashes-prompt-delete",
        action="store_true",
        help="Prompt to delete duplicate files based on hashes",
    )
    action_group.add_argument(
        "--compare-indexes",
        action="store_true",
        help="Check whether every file in --other-index exists in --output-file by hash",
    )
    parser.add_argument(
        "--directory",
        default=os.getcwd(),
        help="Directory to scan (default: current working directory)",
    )
    parser.add_argument(
        "--output-file",
        default=DEFAULT_OUTPUT_FILE,
        help=f"Output YAML file (default: {DEFAULT_OUTPUT_FILE})",
    )
    parser.add_argument(
        "--other-index",
        help="Second YAML index file used with --compare-indexes",
    )
    parser.add_argument(
        "--match-name",
        action="store_true",
        help="With --compare-indexes, require the filename to also exist for matching hashes",
    )
    return parser.parse_args()


def validate_paths(directory_to_scan: str, output_file: str) -> None:
    if not os.path.isdir(directory_to_scan):
        raise ValueError(f"Directory does not exist or is not a directory: {directory_to_scan}")

    if os.path.isdir(output_file):
        raise ValueError(f"Output file points to a directory, not a file: {output_file}")

    output_parent = os.path.dirname(output_file) or "."
    if not os.path.isdir(output_parent):
        raise ValueError(f"Output directory does not exist: {output_parent}")


def validate_existing_file(file_path: str, description: str) -> None:
    if not file_path:
        raise ValueError(f"Missing {description}.")

    if not os.path.isfile(file_path):
        raise ValueError(f"{description} does not exist or is not a file: {file_path}")


def calculate_sha256(file_path: str) -> str:
    sha256_hash = hashlib.sha256()
    with open(file_path, "rb") as f:
        for byte_block in iter(lambda: f.read(1024 * 1024), b""):
            sha256_hash.update(byte_block)
    return sha256_hash.hexdigest()


def human_size(size_bytes: int) -> str:
    units = ["B", "KB", "MB", "GB", "TB", "PB"]
    size = float(size_bytes)

    for unit in units:
        if size < 1024 or unit == units[-1]:
            if unit == "B":
                return f"{int(size)}{unit}"
            if size >= 100:
                return f"{size:.0f}{unit}"
            if size >= 10:
                return f"{size:.1f}{unit}"
            return f"{size:.2f}{unit}"
        size /= 1024.0

    return f"{size_bytes}B"


def get_mime_type(file_path: str) -> str | None:
    mime_type, _ = mimetypes.guess_type(file_path)
    return mime_type


def get_extension(file_path: str) -> str | None:
    _, ext = os.path.splitext(file_path)
    if not ext:
        return None
    return ext.lstrip(".") or None


def get_exif_metadata(file_path: str) -> dict[str, Any]:
    """
    Uses exiftool if available. Returns {} if not available or not applicable.
    """
    if not shutil.which("exiftool"):
        return {}

    try:
        result = subprocess.run(
            ["exiftool", "-j", "-q", "-q", file_path],
            capture_output=True,
            text=True,
            check=True,
        )
        parsed = json.loads(result.stdout)
        if isinstance(parsed, list) and parsed:
            exif_data = parsed[0]
            for key in ["SourceFile", "Directory", "FileName"]:
                exif_data.pop(key, None)
            return exif_data
    except Exception as exc:
        logger.debug("Failed to get exif metadata for %s: %s", file_path, exc)

    return {}


def get_date_created(file_path: str) -> str | None:
    try:
        stat_result = os.stat(file_path)
        birth_time = getattr(stat_result, "st_birthtime", None)
        if birth_time is not None:
            return datetime.fromtimestamp(birth_time).isoformat()
    except Exception:
        pass

    try:
        result = subprocess.run(
            ["stat", "-c", "%w", file_path],
            capture_output=True,
            text=True,
            check=True,
        )
        value = result.stdout.strip()
        if value and value != "-":
            return value
    except Exception:
        pass

    return None


def get_file_info(file_path: str) -> dict[str, Any]:
    file_stats = os.stat(file_path)
    abs_path = os.path.abspath(file_path)

    info: dict[str, Any] = {
        "file": os.path.basename(file_path),
        "folder": os.path.dirname(abs_path),
        "path": abs_path,
        "sha256_hash": calculate_sha256(file_path),
        "date_last_modified": datetime.fromtimestamp(file_stats.st_mtime).isoformat(),
        "date_created": get_date_created(file_path),
        "date_last_accessed": datetime.fromtimestamp(file_stats.st_atime).isoformat(),
        "size": file_stats.st_size,
        "size_human": human_size(file_stats.st_size),
        "extension": get_extension(file_path),
        "mime_type": get_mime_type(file_path),
        "is_symlink": os.path.islink(file_path),
    }

    exif_data = get_exif_metadata(file_path)
    if exif_data:
        info["exif"] = exif_data

    return info


def validate_loaded_index(data: Any) -> dict[str, Any]:
    if not isinstance(data, dict):
        raise ValueError(
            f"Unsupported index format in YAML. Expected a mapping with keys "
            f"'version', 'generated_at', and 'contents'."
        )

    version = str(data.get("version"))
    if version != INDEX_VERSION:
        raise ValueError(
            f"Unsupported index version: {version!r}. "
            f"Expected version {INDEX_VERSION!r}."
        )

    if "contents" not in data:
        raise ValueError("Invalid index file: missing 'contents' key.")

    if not isinstance(data["contents"], list):
        raise ValueError("Invalid index file: 'contents' must be a list.")

    if "generated_at" not in data:
        raise ValueError("Invalid index file: missing 'generated_at' key.")

    return data


def load_existing_index(file_path: str) -> dict[str, Any]:
    if not os.path.exists(file_path):
        return {
            "version": INDEX_VERSION,
            "generated_at": datetime.now().isoformat(),
            "contents": [],
        }

    with open(file_path, "r", encoding="utf-8") as f:
        raw = yaml.safe_load(f)

    if raw is None:
        raise ValueError(f"Index file {file_path} is empty.")

    return validate_loaded_index(raw)


def generate_hash_for_directory(directory_path: str, output_yaml_file: str) -> list[dict[str, Any]]:
    files_data = []

    output_abs = os.path.abspath(output_yaml_file)

    for root, dirs, files in os.walk(directory_path):
        dirs.sort()
        files.sort()

        for file in files:
            file_path = os.path.join(root, file)
            abs_file_path = os.path.abspath(file_path)

            if abs_file_path == output_abs:
                logger.debug("Skipping output file %s", file_path)
                continue

            if not os.path.isfile(file_path):
                continue

            logger.info("Looking at file %s", file_path)
            file_info = get_file_info(file_path)
            files_data.append(file_info)

    return files_data


def build_index_payload(contents: list[dict[str, Any]]) -> dict[str, Any]:
    return {
        "version": INDEX_VERSION,
        "generated_at": datetime.now().isoformat(),
        "contents": contents,
    }


def create_index(directory_to_scan: str, output_yaml_file: str) -> None:
    files_data = generate_hash_for_directory(directory_to_scan, output_yaml_file)
    payload = build_index_payload(files_data)

    with open(output_yaml_file, "w", encoding="utf-8") as yaml_file:
        yaml.safe_dump(payload, yaml_file, default_flow_style=False, sort_keys=False, allow_unicode=True)

    logger.info("File index created and saved in %s", output_yaml_file)


def add_missing(directory_to_scan: str, output_yaml_file: str) -> None:
    existing_index = load_existing_index(output_yaml_file)
    existing_contents = existing_index["contents"]

    # Use path as the unique key rather than just filename
    existing_files = {
        file_info.get("path") or os.path.join(file_info["folder"], file_info["file"]): file_info
        for file_info in existing_contents
    }

    new_files_data = []

    output_abs = os.path.abspath(output_yaml_file)

    for root, dirs, files in os.walk(directory_to_scan):
        dirs.sort()
        files.sort()

        for file in files:
            file_path = os.path.join(root, file)
            abs_file_path = os.path.abspath(file_path)

            if abs_file_path == output_abs:
                continue

            if abs_file_path not in existing_files:
                logger.info("Adding missing file %s", abs_file_path)
                file_info = get_file_info(file_path)
                new_files_data.append(file_info)

    if new_files_data:
        updated_data = existing_contents + new_files_data
        updated_payload = build_index_payload(updated_data)

        with open(output_yaml_file, "w", encoding="utf-8") as yaml_file:
            yaml.safe_dump(updated_payload, yaml_file, default_flow_style=False, sort_keys=False, allow_unicode=True)

        logger.info("Missing files added to index and saved in %s", output_yaml_file)
    else:
        logger.info("No missing files found to add.")


def find_duplicate_hashes(output_yaml_file: str) -> dict[str, list[str]]:
    existing_index = load_existing_index(output_yaml_file)
    existing_contents = existing_index["contents"]

    hash_map: dict[str, list[str]] = {}
    for file_info in existing_contents:
        sha256_hash = file_info["sha256_hash"]
        path = file_info.get("path") or os.path.join(file_info["folder"], file_info["file"])

        if sha256_hash in hash_map:
            hash_map[sha256_hash].append(path)
        else:
            hash_map[sha256_hash] = [path]

    duplicates = {sha256_hash: paths for sha256_hash, paths in hash_map.items() if len(paths) > 1}
    return duplicates


def print_duplicate_hashes(duplicates: dict[str, list[str]]) -> None:
    if not duplicates:
        print("No duplicate hashes found.")
        return

    for sha256_hash, paths in duplicates.items():
        print(f"Hash: {sha256_hash}")
        for path in paths:
            print(f" -> {path}")


def prompt_delete_duplicates(duplicates: dict[str, list[str]]) -> None:
    if not duplicates:
        print("No duplicate hashes found.")
        return

    for sha256_hash, paths in duplicates.items():
        print(f"\nDuplicate files for hash: {sha256_hash}")
        mutable_paths = list(paths)

        while len(mutable_paths) > 1:
            for i, path in enumerate(mutable_paths, 1):
                print(f"[{i}] {path}")

            try:
                to_delete = input("Choose a file number to delete or 'skip' to keep the rest: ")
                if to_delete.lower() == "skip":
                    break

                index = int(to_delete) - 1
                if 0 <= index < len(mutable_paths):
                    file_to_delete = mutable_paths.pop(index)
                    os.remove(file_to_delete)
                    print(f"Deleted: {file_to_delete}")
                else:
                    print("Invalid selection. Please try again.")
            except (ValueError, IndexError):
                print("Invalid input. Please enter a number corresponding to the file or 'skip'.")
            except OSError as exc:
                print(f"Failed to delete file: {exc}")


def build_hash_name_lookup(index_contents: list[dict[str, Any]]) -> dict[str, set[str]]:
    lookup: dict[str, set[str]] = {}
    for file_info in index_contents:
        sha256_hash = file_info["sha256_hash"]
        file_name = file_info["file"]
        lookup.setdefault(sha256_hash, set()).add(file_name)
    return lookup


def compare_indexes(output_yaml_file: str, other_index_file: str, match_name: bool) -> bool:
    existing_index = load_existing_index(output_yaml_file)
    other_index = load_existing_index(other_index_file)

    existing_lookup = build_hash_name_lookup(existing_index["contents"])
    missing_hashes: list[dict[str, str]] = []
    name_mismatches: list[dict[str, str]] = []
    matched_files = 0

    for file_info in other_index["contents"]:
        sha256_hash = file_info["sha256_hash"]
        file_name = file_info["file"]
        path = file_info.get("path") or os.path.join(file_info["folder"], file_info["file"])
        existing_names = existing_lookup.get(sha256_hash)

        if not existing_names:
            missing_hashes.append(
                {
                    "path": path,
                    "file": file_name,
                    "sha256_hash": sha256_hash,
                }
            )
            continue

        if match_name and file_name not in existing_names:
            name_mismatches.append(
                {
                    "path": path,
                    "file": file_name,
                    "sha256_hash": sha256_hash,
                }
            )
            continue

        matched_files += 1

    print(f"Compared {len(other_index['contents'])} files from {other_index_file}")
    print(f"Against {len(existing_index['contents'])} files in {output_yaml_file}")
    print(f"Matched: {matched_files}")
    print(f"Missing by hash: {len(missing_hashes)}")

    if match_name:
        print(f"Hash matched but filename missing: {len(name_mismatches)}")

    if missing_hashes:
        print("\nMissing hashes:")
        for item in missing_hashes:
            print(f" - {item['path']} [{item['sha256_hash']}]")

    if match_name and name_mismatches:
        print("\nHash matched but filename not found:")
        for item in name_mismatches:
            print(f" - {item['path']} [{item['sha256_hash']}]")

    return not missing_hashes and (not match_name or not name_mismatches)


def main() -> None:
    args = parse_args()

    loglevel = os.getenv("LOGLEVEL", "INFO").upper()
    logging.basicConfig(level=getattr(logging, loglevel, logging.INFO))

    directory_to_scan = os.path.abspath(args.directory)
    output_file = os.path.abspath(args.output_file)

    try:
        if args.create_index:
            validate_paths(directory_to_scan, output_file)
            create_index(directory_to_scan, output_file)
        elif args.add_missing:
            validate_paths(directory_to_scan, output_file)
            add_missing(directory_to_scan, output_file)
        elif args.duplicate_hashes:
            validate_existing_file(output_file, "Index file")
            duplicates = find_duplicate_hashes(output_file)
            print_duplicate_hashes(duplicates)
        elif args.duplicate_hashes_prompt_delete:
            validate_existing_file(output_file, "Index file")
            duplicates = find_duplicate_hashes(output_file)
            prompt_delete_duplicates(duplicates)
        elif args.compare_indexes:
            other_index_file = os.path.abspath(args.other_index) if args.other_index else None
            validate_existing_file(output_file, "Primary index file")
            validate_existing_file(other_index_file, "Comparison index file")
            success = compare_indexes(output_file, other_index_file, args.match_name)
            if not success:
                raise SystemExit(1)
    except ValueError as exc:
        logger.error(str(exc))
        raise SystemExit(1)


if __name__ == "__main__":
    main()
